// Package geom provides Geometry4326, the Go type sqlc binds PostGIS geometry
// columns to (see sqlc.yaml overrides). It carries the raw (E)WKB bytes from the
// database — decode them with the geometry library of your choice. SRID 4326
// (WGS84) is the assumed convention for {{.Module}}.
//
// Generated by the ix core-schema block because database.postgis = true.
package geom

import (
	"database/sql/driver"
	"encoding/hex"
	"fmt"
)

// Geometry4326 holds a PostGIS geometry as (E)WKB bytes.
type Geometry4326 struct {
	WKB []byte
}

// Scan implements sql.Scanner. Over lib/pq's text protocol PostGIS returns
// geometry as a hex-encoded EWKB string (delivered as []byte); raw bytes are
// also accepted.
func (g *Geometry4326) Scan(src any) error {
	switch v := src.(type) {
	case nil:
		g.WKB = nil
		return nil
	case []byte:
		if decoded, err := hex.DecodeString(string(v)); err == nil {
			g.WKB = decoded
		} else {
			g.WKB = append([]byte(nil), v...)
		}
		return nil
	case string:
		decoded, err := hex.DecodeString(v)
		if err != nil {
			return fmt.Errorf("geom: scan: %w", err)
		}
		g.WKB = decoded
		return nil
	default:
		return fmt.Errorf("geom: cannot scan %T into Geometry4326", src)
	}
}

// Value implements driver.Valuer, sending hex-encoded WKB that PostGIS accepts.
func (g Geometry4326) Value() (driver.Value, error) {
	if g.WKB == nil {
		return nil, nil
	}
	return hex.EncodeToString(g.WKB), nil
}

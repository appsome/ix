version: "2"
sql:
  - schema: "internal/datastore/schema.sql"
    queries: "internal/datastore/queries/"
    engine: "postgresql"
    gen:
      go:
        package: "db"
        out: "internal/datastore/pkg/db"
        sql_package: "database/sql"
        emit_json_tags: true
        emit_interface: true
        emit_empty_slices: true
        emit_pointers_for_null_types: true
{{- if .PostGIS }}
        overrides:
          - db_type: "geometry"
            go_type:
              import: "{{.Module}}/internal/datastore/pkg/geom"
              type: "Geometry4326"
              pointer: true
          - db_type: "pg_catalog.geometry"
            go_type:
              import: "{{.Module}}/internal/datastore/pkg/geom"
              type: "Geometry4326"
              pointer: true
{{- end }}

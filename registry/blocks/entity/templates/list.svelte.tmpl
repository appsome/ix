<!--
  {{.NamePascal}} list page for {{.Module}}.
  Generated by `ix add entity --name {{.Name}} --frontend`. The page query
  lives in ./+page.gql ({{.NamePluralPascal}}List); houdini generates the typed
  load. Plain Svelte you own — re-running the generator never overwrites it.
-->
<script lang="ts">
  import type { PageData } from './$houdini';

  export let data: PageData;

  const pageSize = 50;

  type OrderField = 'ID' | 'NAME';

  let page = 0;
  let orderBy: OrderField = 'ID';
  let orderDesc = true;

  $: ({ {{.NamePluralPascal}}List } = data);
  $: rows = ${{.NamePluralPascal}}List.data?.{{.NamePluralCamel}}.items ?? [];
  $: totalCount = ${{.NamePluralPascal}}List.data?.{{.NamePluralCamel}}.totalCount ?? 0;
  $: pageCount = Math.max(1, Math.ceil(totalCount / pageSize));

  function load() {
    {{.NamePluralPascal}}List.fetch({
      variables: { first: pageSize, offset: page * pageSize, orderBy, orderDesc }
    });
  }

  function goTo(p: number) {
    page = p;
    load();
  }

  function sortBy(field: OrderField) {
    if (orderBy === field) {
      orderDesc = !orderDesc;
    } else {
      orderBy = field;
      orderDesc = false;
    }
    page = 0;
    load();
  }

  // Takes orderBy/orderDesc as args so Svelte re-renders the headers on change.
  function arrow(field: OrderField, by: OrderField, desc: boolean): string {
    if (by !== field) return '';
    return desc ? ' ▼' : ' ▲';
  }
</script>

<h1>{{.NamePluralPascal}}</h1>
<p><a href="/{{.NamePlural}}/new">New {{.NameCamel}}</a></p>

{#if ${{.NamePluralPascal}}List.fetching}
  <p>Loading…</p>
{:else}
  <table>
    <thead><tr>
      <th style="cursor: pointer" on:click={() => sortBy('ID')}>ID{arrow('ID', orderBy, orderDesc)}</th>
      <th style="cursor: pointer" on:click={() => sortBy('NAME')}>Name{arrow('NAME', orderBy, orderDesc)}</th>
    </tr></thead>
    <tbody>
      {#each rows as row}
        <tr><td><a href="/{{.NamePlural}}/{row.id}">{row.id}</a></td><td>{row.name}</td></tr>
      {/each}
    </tbody>
  </table>
  <p>
    {totalCount} record{totalCount === 1 ? '' : 's'}
    {#if pageCount > 1}
      · page {page + 1} of {pageCount}
      <button disabled={page === 0} on:click={() => goTo(page - 1)}>‹ prev</button>
      <button disabled={page >= pageCount - 1} on:click={() => goTo(page + 1)}>next ›</button>
    {/if}
  </p>
{/if}

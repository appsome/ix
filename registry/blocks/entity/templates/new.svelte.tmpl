<!--
  {{.NamePascal}} create page for {{.Module}}.
  Generated by `ix add entity --name {{.Name}} --frontend`. The create mutation
  is an inline Houdini store. Plain Svelte you own.
-->
<script lang="ts">
  import { goto } from '$app/navigation';
  import { graphql } from '$houdini';

  const create{{.NamePascal}} = graphql(`
    mutation Create{{.NamePascal}}($name: String!) {
      create{{.NamePascal}}(name: $name) {
        id
        name
      }
    }
  `);

  let name = '';
  let saving = false;

  async function save() {
    saving = true;
    const res = await create{{.NamePascal}}.mutate({ name });
    saving = false;
    const id = res.data?.create{{.NamePascal}}?.id;
    if (id) await goto(`/{{.NamePlural}}/${id}`);
  }
</script>

<h1>New {{.NameCamel}}</h1>

<form on:submit|preventDefault={save}>
  <label>
    Name
    <input name="name" bind:value={name} required />
  </label>
  <button type="submit" disabled={saving}>{saving ? 'Saving…' : 'Create'}</button>
</form>

<p><a href="/{{.NamePlural}}">← back to {{.NamePluralCamel}}</a></p>

<!--
  {{.NamePascal}} show/edit page for {{.Module}}.
  Generated by `ix add entity --name {{.Name}} --frontend`. The page query
  lives in ./+page.gql ({{.NamePascal}}Detail); the update/delete mutations are
  inline Houdini stores. Plain Svelte you own.
-->
<script lang="ts">
  import { goto } from '$app/navigation';
  import { graphql } from '$houdini';
  import type { PageData } from './$houdini';

  export let data: PageData;

  $: ({ {{.NamePascal}}Detail } = data);
  $: record = ${{.NamePascal}}Detail.data?.{{.NameCamel}};

  // Edit form state, seeded from the query once it resolves.
  let name: string | undefined;
  $: if (name === undefined && record) name = record.name;
  let saving = false;

  const update{{.NamePascal}} = graphql(`
    mutation Update{{.NamePascal}}($id: ID!, $name: String!) {
      update{{.NamePascal}}(id: $id, name: $name) {
        id
        name
      }
    }
  `);

  const delete{{.NamePascal}} = graphql(`
    mutation Delete{{.NamePascal}}($id: ID!) {
      delete{{.NamePascal}}(id: $id)
    }
  `);

  async function save() {
    if (!record || name === undefined) return;
    saving = true;
    await update{{.NamePascal}}.mutate({ id: record.id, name });
    saving = false;
  }

  async function remove() {
    if (!record) return;
    if (!confirm(`Delete {{.NameCamel}} #${record.id}?`)) return;
    await delete{{.NamePascal}}.mutate({ id: record.id });
    await goto('/{{.NamePlural}}');
  }
</script>

{#if ${{.NamePascal}}Detail.fetching}
  <p>Loading…</p>
{:else if record}
  <h1>{{.NamePascal}} #{record.id}</h1>
  <form on:submit|preventDefault={save}>
    <label>
      Name
      <input name="name" bind:value={name} required />
    </label>
    <button type="submit" disabled={saving}>{saving ? 'Saving…' : 'Save'}</button>
    <button type="button" on:click={remove}>Delete</button>
  </form>
{:else}
  <p>Not found.</p>
{/if}

<p><a href="/{{.NamePlural}}">← back to {{.NamePluralCamel}}</a></p>

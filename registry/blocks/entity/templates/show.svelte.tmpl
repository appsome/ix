<script lang="ts">
  import { page } from '$app/stores';
  import { onMount } from 'svelte';

  type {{.NamePascal}} = { id: string; name: string };
  let record: {{.NamePascal}} | null = null;
  let loading = true;

  onMount(async () => {
    const id = $page.params.id;
    // TODO: replace with the generated Houdini query for `{{.NameCamel}}(id:)`.
    const res = await fetch('/query', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ query: `query($id: ID!) { {{.NameCamel}}(id: $id) { id name } }`, variables: { id } })
    });
    const json = await res.json();
    record = json?.data?.{{.NameCamel}} ?? null;
    loading = false;
  });
</script>

{#if loading}
  <p>Loading…</p>
{:else if record}
  <h1>{{.NamePascal}} #{record.id}</h1>
  <dl><dt>Name</dt><dd>{record.name}</dd></dl>
{:else}
  <p>Not found.</p>
{/if}

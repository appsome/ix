// Package server wires the chi router, the gqlgen handler, a GraphQL
// playground, and a health check for {{.Module}}.
package server

import (
	"context"
	"net/http"
	"time"

	"github.com/99designs/gqlgen/graphql/handler"
	"github.com/99designs/gqlgen/graphql/playground"
	"github.com/go-chi/chi/v5"
	"github.com/go-chi/chi/v5/middleware"

	"database/sql"

	"{{.Module}}/internal/api/generated"
	"{{.Module}}/internal/api/resolver"
)

// Server holds the constructed HTTP handler.
type Server struct {
	handler http.Handler
}

// New builds the server around the database handle. Runtime-glue services
// constructed in main() can be threaded in by extending resolver.New.
func New(database *sql.DB) *Server {
	r := chi.NewRouter()
	r.Use(middleware.RequestID, middleware.RealIP, middleware.Recoverer)
	r.Use(middleware.Timeout(60 * time.Second))

	r.Get("/health", func(w http.ResponseWriter, _ *http.Request) {
		w.WriteHeader(http.StatusOK)
		_, _ = w.Write([]byte("ok"))
	})

	// Blocks mount additional HTTP routes at the anchor below (r and database
	// are in scope) — e.g. jobs-admin mounts its /admin/jobs API there.
	// ix:routes

	gql := handler.NewDefaultServer(generated.NewExecutableSchema(generated.Config{
		Resolvers: resolver.New(database),
	}))
	r.Handle("/query", gql)
	r.Get("/", playground.Handler("{{.Module}}", "/query"))

	return &Server{handler: r}
}

// Start serves on port until ctx is cancelled, then shuts down gracefully.
func (s *Server) Start(ctx context.Context, port string) error {
	httpSrv := &http.Server{Addr: ":" + port, Handler: s.handler}

	errCh := make(chan error, 1)
	go func() {
		if err := httpSrv.ListenAndServe(); err != nil && err != http.ErrServerClosed {
			errCh <- err
		}
	}()

	select {
	case err := <-errCh:
		return err
	case <-ctx.Done():
		shutdownCtx, cancel := context.WithTimeout(context.Background(), 20*time.Second)
		defer cancel()
		return httpSrv.Shutdown(shutdownCtx)
	}
}

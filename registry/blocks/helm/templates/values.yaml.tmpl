replicaCount: 2

image:
  repository: {{.App}}
  tag: latest
  pullPolicy: IfNotPresent

service:
  type: ClusterIP
  port: 8080

# Run the Atlas migrations image as a pre-install/pre-upgrade hook.
migrations:
  enabled: true
  image:
    repository: {{.App}}-migrations
    tag: latest

# Database connection. In production point dbSecret at an existing Secret with
# DB_HOST/DB_NAME/DB_USER/DB_PASS/DATABASE_URL keys.
dbSecret: ""

env:
  SSL_MODE: require
  REST_PORT: "8080"

resources:
  requests:
    cpu: 50m
    memory: 64Mi
  limits:
    cpu: 500m
    memory: 256Mi

autoscaling:
  enabled: false
  minReplicas: 2
  maxReplicas: 10
  targetCPUUtilizationPercentage: 80

ingress:
  enabled: false
  className: ""
  host: {{.App}}.example.com
  annotations: {}

podAnnotations: {}
nodeSelector: {}
tolerations: []
affinity: {}
